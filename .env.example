# GEMINI_API_KEY or GOOGLE_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects GEMINI_API_KEY at runtime from user secrets.
# You can also use GOOGLE_API_KEY on platforms like Vercel or GitHub when executing outside of AI Studio.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GOOGLE_API_KEY="MY_GOOGLE_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
